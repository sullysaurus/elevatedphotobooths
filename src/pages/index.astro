---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#191511" />
    <meta
      name="description"
      content="Premium photo booth rentals for weddings, corporate events, parties, proms, and quinceañeras across Raleigh–Durham, North Carolina."
    />
    <title>Elevated Photo Booths | Raleigh–Durham Photo Booth Rentals</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:opsz,wght@6..96,400;6..96,500;6..96,600&family=DM+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Elevated Photo Booths",
        "description": "Premium photo booth rentals serving Raleigh–Durham and beyond.",
        "telephone": "+1-919-307-6130",
        "email": "elevatedphotoboothsnc@gmail.com",
        "areaServed": ["Raleigh", "Durham", "North Carolina"],
        "url": "https://www.elevatedphotoboothsnc.com/",
        "sameAs": [
          "https://www.instagram.com/elevated.photobooths/",
          "https://www.facebook.com/profile.php?id=61582704352198"
        ]
      }
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header" data-header>
      <a class="brand" href="#top" aria-label="Elevated Photo Booths home">
        <img src="/assets/logo.webp" alt="" />
        <span>Elevated <small>Photo Booths</small></span>
      </a>

      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
        <span></span><span></span>
        <span class="sr-only">Open menu</span>
      </button>

      <nav id="site-nav" class="site-nav" aria-label="Main navigation">
        <a href="#booths">The booths</a>
        <a href="#experience">Experience</a>
        <a href="#reviews">Kind words</a>
        <a href="#about">About</a>
        <a class="nav-cta" href="#quote">Check your date <span aria-hidden="true">↗</span></a>
      </nav>
    </header>

    <main id="main">
      <section class="hero" id="top" aria-labelledby="hero-title">
        <div class="hero-media" aria-hidden="true">
          <img src="/assets/owners.webp" alt="" fetchpriority="high" />
        </div>
        <div class="hero-grain" aria-hidden="true"></div>

        <div class="hero-content">
          <p class="eyebrow reveal">Raleigh–Durham, North Carolina</p>
          <h1 id="hero-title" class="reveal reveal-delay-1">
            The party<br />
            <em>looks good</em><br />
            on you.
          </h1>
          <div class="hero-bottom reveal reveal-delay-2">
            <p>Studio-quality photos. Instant keepsakes.<br />A guest experience they’ll talk about.</p>
            <a class="button button-light" href="#quote">Get a free quote <span aria-hidden="true">↗</span></a>
          </div>
        </div>

        <div class="hero-stamp" aria-hidden="true">
          <svg viewBox="0 0 140 140" role="img">
            <defs><path id="circle" d="M70,70 m-49,0 a49,49 0 1,1 98,0 a49,49 0 1,1 -98,0" /></defs>
            <text><textPath href="#circle">ELEVATE THE MOMENT • KEEP THE MEMORY • </textPath></text>
          </svg>
          <span>EP</span>
        </div>

        <a class="scroll-cue" href="#intro"><span>Scroll to celebrate</span><i></i></a>
      </section>

      <div class="ticker" aria-label="Event types we serve">
        <div class="ticker-track">
          <span>Weddings</span><i>✦</i><span>Corporate</span><i>✦</i><span>Galas</span><i>✦</i><span>Birthdays</span><i>✦</i><span>Quinceañeras</span><i>✦</i><span>Proms</span><i>✦</i>
          <span aria-hidden="true">Weddings</span><i aria-hidden="true">✦</i><span aria-hidden="true">Corporate</span><i aria-hidden="true">✦</i><span aria-hidden="true">Galas</span><i aria-hidden="true">✦</i><span aria-hidden="true">Birthdays</span><i aria-hidden="true">✦</i><span aria-hidden="true">Quinceañeras</span><i aria-hidden="true">✦</i><span aria-hidden="true">Proms</span><i aria-hidden="true">✦</i>
        </div>
      </div>

      <section class="intro section" id="intro">
        <div class="section-label"><span>01</span> Why Elevated</div>
        <div class="intro-copy">
          <p class="kicker">More than a photo booth</p>
          <h2>Your favorite people,<br /><em>at their absolute best.</em></h2>
          <div class="intro-detail">
            <p>
              We create the kind of space where everyone lets loose—from your flower girl to your CEO. Beautiful lighting, thoughtful details, and a warm attendant make every frame feel effortless.
            </p>
            <p>
              You get crisp photos and a polished, stress-free setup. Your guests get a reason to come back again and again.
            </p>
          </div>
        </div>
        <div class="mini-proof">
          <strong>12/10</strong>
          <span>“Would use them again.”<br />— Jennifer F.</span>
        </div>
      </section>

      <section class="booths section" id="booths" aria-labelledby="booths-title">
        <div class="section-heading">
          <div class="section-label"><span>02</span> Meet the lineup</div>
          <div>
            <p class="kicker">One great night. Four ways to capture it.</p>
            <h2 id="booths-title">Find your <em>perfect booth.</em></h2>
          </div>
          <p class="section-note">Not sure which one fits? Tell us about your event and we’ll point you in the right direction.</p>
        </div>

        <div class="booth-grid">
          <article class="booth-card booth-card-featured">
            <a href="#quote" data-booth-link="DSLR Booth" aria-label="Ask about the DSLR booth">
              <div class="booth-image">
                <img src="/assets/dslr.webp" alt="DSLR photo booth setup with studio lighting at an event" loading="lazy" />
                <span class="pill">Most loved</span>
                <span class="card-arrow" aria-hidden="true">↗</span>
              </div>
              <div class="booth-copy">
                <div><span class="card-number">01</span><h3>DSLR<br />Studio Booth</h3></div>
                <p>Our signature experience—studio lighting, professional camera quality, and unlimited prints.</p>
                <ul><li>Weddings</li><li>Galas</li><li>Corporate</li></ul>
              </div>
            </a>
          </article>

          <article class="booth-card">
            <a href="#quote" data-booth-link="360 Booth" aria-label="Ask about the 360 booth">
              <div class="booth-image">
                <img src="/assets/360.webp" alt="360 video booth with colored lighting and velvet ropes" loading="lazy" />
                <span class="card-arrow" aria-hidden="true">↗</span>
              </div>
              <div class="booth-copy">
                <div><span class="card-number">02</span><h3>360<br />Video Booth</h3></div>
                <p>A cinematic, slow-motion moment with room for up to four guests and instant sharing.</p>
                <ul><li>High energy</li><li>Slow-mo</li><li>Shareable</li></ul>
              </div>
            </a>
          </article>

          <article class="booth-card">
            <a href="#quote" data-booth-link="iPad Booth" aria-label="Ask about the iPad booth">
              <div class="booth-image">
                <img src="/assets/ipad.webp" alt="Modern iPad selfie booth with ring light" loading="lazy" />
                <span class="card-arrow" aria-hidden="true">↗</span>
              </div>
              <div class="booth-copy">
                <div><span class="card-number">03</span><h3>iPad<br />Selfie Booth</h3></div>
                <p>Compact, interactive, and endlessly fun with prints, GIFs, boomerangs, and text sharing.</p>
                <ul><li>Birthdays</li><li>Community</li><li>Parties</li></ul>
              </div>
            </a>
          </article>

          <article class="booth-card booth-card-price">
            <a href="#quote" data-booth-link="Drop-Off Booth" aria-label="Ask about the drop-off booth">
              <div class="booth-image">
                <img src="/assets/dropoff.webp" alt="Black drop-off photo booth in front of a sequin backdrop" loading="lazy" />
                <span class="price-badge"><small>All day</small>$350</span>
                <span class="card-arrow" aria-hidden="true">↗</span>
              </div>
              <div class="booth-copy">
                <div><span class="card-number">04</span><h3>All-Day<br />Drop-Off</h3></div>
                <p>All the fun, all day. We deliver, set up, and collect it when the celebration is done.</p>
                <ul><li>Budget-friendly</li><li>Digital</li><li>Easy</li></ul>
              </div>
            </a>
          </article>
        </div>
      </section>

      <section class="experience" id="experience" aria-labelledby="experience-title">
        <div class="experience-photo">
          <img src="/assets/owners.webp" alt="Wedding guests smiling together in a photo booth" loading="lazy" />
          <div class="photo-caption"><span>Real guests</span><span>Real good time</span></div>
        </div>
        <div class="experience-copy">
          <div class="section-label"><span>03</span> The experience</div>
          <p class="kicker">Your event, handled</p>
          <h2 id="experience-title">You celebrate.<br /><em>We’ll get the shot.</em></h2>
          <div class="steps">
            <article><span>01</span><div><h3>Tell us the vision</h3><p>Share your date, venue, vibe, and must-haves. We’ll help match you with the right booth.</p></div></article>
            <article><span>02</span><div><h3>Make it yours</h3><p>Choose a backdrop, custom photo design, and thoughtful add-ons that fit your event.</p></div></article>
            <article><span>03</span><div><h3>Show up & shine</h3><p>We handle delivery, setup, guest support, and teardown. You keep every memory.</p></div></article>
          </div>
          <a class="text-link" href="#quote">Start planning your booth <span aria-hidden="true">→</span></a>
        </div>
      </section>

      <section class="reviews section" id="reviews" aria-labelledby="reviews-title">
        <div class="reviews-top">
          <div class="section-label"><span>04</span> Kind words</div>
          <div class="review-heading">
            <span class="stars" aria-label="5 out of 5 stars">★★★★★</span>
            <h2 id="reviews-title">The reviews are <em>in.</em></h2>
          </div>
          <div class="review-controls">
            <button type="button" data-review-prev aria-label="Previous review">←</button>
            <span><b data-review-current>01</b> / 03</span>
            <button type="button" data-review-next aria-label="Next review">→</button>
          </div>
        </div>

        <div class="review-stage" aria-live="polite">
          <figure class="review is-active">
            <blockquote>“The photobooth was packed during the whole wedding and everyone loved it. I cannot recommend Elevated Photo Booths enough!”</blockquote>
            <figcaption><strong>Samantha Steward</strong><span>Wedding client</span></figcaption>
          </figure>
          <figure class="review">
            <blockquote>“They’re timely, have great customer service, and truly elevate your event to the next level.”</blockquote>
            <figcaption><strong>Josh Morales</strong><span>Repeat client</span></figcaption>
          </figure>
          <figure class="review">
            <blockquote>“The setup was sleek, the photos were crystal clear, and our guests couldn’t stop taking pictures all night.”</blockquote>
            <figcaption><strong>Yanisha Del Rosario</strong><span>Private event</span></figcaption>
          </figure>
        </div>
      </section>

      <section class="about section" id="about">
        <div class="about-mark" aria-hidden="true"><span>E</span><span>P</span></div>
        <div class="about-copy">
          <div class="section-label"><span>05</span> Our promise</div>
          <p class="kicker">Veteran-owned & operated</p>
          <h2>Good people.<br /><em>Great pictures.</em></h2>
          <p>
            Elevated Photo Booths was built on two simple principles: exceptional photos and exceptional service. From setup to smiles, we take care of every detail so you can relax and enjoy the moment.
          </p>
          <p>
            Proudly serving Raleigh, Durham, and celebrations across North Carolina.
          </p>
          <div class="signature">— The Elevated team</div>
        </div>
        <div class="about-photo">
          <img src="/assets/dslr.webp" alt="Elevated Photo Booths attendant helping guests at an event" loading="lazy" />
          <span>Service-first,<br />always.</span>
        </div>
      </section>

      <section class="quote" id="quote" aria-labelledby="quote-title">
        <div class="quote-intro">
          <div class="section-label section-label-light"><span>06</span> Let’s make a memory</div>
          <p class="kicker">Now booking</p>
          <h2 id="quote-title">Your date.<br />Your people.<br /><em>Your moment.</em></h2>
          <p>Tell us a little about the celebration. We’ll follow up with availability and a personalized recommendation.</p>
          <div class="direct-contact">
            <a href="tel:+19193076130">919 307 6130</a>
            <a href="mailto:elevatedphotoboothsnc@gmail.com">elevatedphotoboothsnc@gmail.com</a>
          </div>
        </div>

        <form class="quote-form" data-quote-form>
          <div class="field-row">
            <label>First name<input name="firstName" autocomplete="given-name" required /></label>
            <label>Last name<input name="lastName" autocomplete="family-name" required /></label>
          </div>
          <label>Email address<input type="email" name="email" autocomplete="email" required /></label>
          <div class="field-row">
            <label>Event date<input type="date" name="date" /></label>
            <label>Event type
              <select name="eventType"><option value="">Choose one</option><option>Wedding</option><option>Corporate event</option><option>Birthday</option><option>Quinceañera</option><option>Prom or school event</option><option>Other celebration</option></select>
            </label>
          </div>
          <label>Which booth has your eye?
            <select name="booth" data-booth-select><option value="">Help me choose</option><option>DSLR Booth</option><option>360 Booth</option><option>iPad Booth</option><option>Drop-Off Booth</option></select>
          </label>
          <label>Tell us about the vibe<textarea name="message" rows="3" placeholder="Venue, guest count, colors, big ideas…"></textarea></label>
          <button class="button button-copper" type="submit">Check my date <span aria-hidden="true">↗</span></button>
          <p class="form-note">No pressure, no spam—just a helpful reply from our team.</p>
        </form>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-brand">
        <img src="/assets/logo.webp" alt="" />
        <span>Elevated<br />Photo Booths</span>
      </div>
      <div class="footer-links">
        <div><small>Explore</small><a href="#booths">The booths</a><a href="#experience">Experience</a><a href="#reviews">Reviews</a></div>
        <div><small>Follow</small><a href="https://www.instagram.com/elevated.photobooths/" target="_blank" rel="noreferrer">Instagram ↗</a><a href="https://www.facebook.com/profile.php?id=61582704352198" target="_blank" rel="noreferrer">Facebook ↗</a></div>
        <div><small>Serving</small><span>Raleigh</span><span>Durham</span><span>North Carolina & beyond</span></div>
      </div>
      <div class="footer-bottom"><span>© <span data-year></span> Elevated Photo Booths</span><span>Veteran owned & operated</span><a href="#top">Back to top ↑</a></div>
    </footer>

    <div class="form-toast" data-toast role="status" aria-live="polite">
      <strong>Your email app is opening.</strong>
      <span>We can’t wait to hear about your event.</span>
    </div>

    <script src="../scripts/main.js"></script>
  </body>
</html>
